# AI Interview Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3001
NODE_ENV=development

# =============================================================================
# STT (Speech-to-Text) Configuration
# =============================================================================
# Options: mock, whisper, azure, deepgram
STT_PROVIDER=mock

# Azure Speech SDK (if using Azure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Deepgram API (if using Deepgram)
DEEPGRAM_API_KEY=

# =============================================================================
# LLM Configuration
# =============================================================================
# Options: openai, anthropic, google, ollama, local
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-api-key
LLM_MODEL=gpt-3.5-turbo

# Anthropic (if using Claude)
ANTHROPIC_API_KEY=

# Google (if using Gemini)
GOOGLE_API_KEY=

# Ollama (if using local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500
LLM_TIMEOUT=30000

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_STEALTH=true
ENABLE_RAG=true

# =============================================================================
# RAG Configuration
# =============================================================================
# Embedding model for local processing
EMBEDDING_MODEL=bge-small-zh

# Vector store (optional, for persistent storage)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# =============================================================================
# Security
# =============================================================================
# Session secret (generate a random string)
SESSION_SECRET=your-session-secret-key

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
LOG_SANITIZE=true
